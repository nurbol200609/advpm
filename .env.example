# UniQueue Frontend Environment Variables

# Backend API Base URL
# For local development: https://advpm.onrender.com
# For production: https://advpm.onrender.com
VITE_API_BASE_URL=https://advpm.onrender.com

# Force mock mode (for offline demo)
# Set to 'true' to always use mock data instead of real API
# VITE_FORCE_MOCK_MODE=false

# Enable mock authentication (for demo purposes)
# Set to 'false' to use real authentication
# VITE_USE_MOCK_AUTH=false